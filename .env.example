# Luxury28 Configuration Example
# Copy this file to .env.local and fill in the values. Do NOT commit .env.local to version control.

# Supabase Keys
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Payments & Logistics (Mock or Live)
XENDIT_SECRET_KEY=your-xendit-secret-key
BITESHIP_API_KEY=your-biteship-api-key

# Prototype Environment Settings
# Set this to "true" to enable the top warning banner and the floating account credentials panel.
NEXT_PUBLIC_IS_PROTOTYPE=true

# Test Accounts (Visible only when NEXT_PUBLIC_IS_PROTOTYPE=true)
NEXT_PUBLIC_TEST_ADMIN_EMAIL=admin1@gmail.com
NEXT_PUBLIC_TEST_ADMIN_PASS=admin123

NEXT_PUBLIC_TEST_STAFF_EMAIL=staff1@gmail.com
NEXT_PUBLIC_TEST_STAFF_PASS=staff123

NEXT_PUBLIC_TEST_CUSTOMER_EMAIL=customer1@gmail.com
NEXT_PUBLIC_TEST_CUSTOMER_PASS=customer123
