# Luxury28 — Environment Configuration Template
# Copy this file to .env.local and populate the values.
# IMPORTANT: Do NOT commit .env.local or .env to version control.

# ─── Supabase Configuration ──────────────────────────────────────────────────
# Found in Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Service role key is required for server actions/webhooks that bypass Row-Level Security.
# WARNING: Keep this secret and NEVER expose it to the client side.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Xendit Payment Integration (Indonesia-first gateway) ───────────────────
# Retrieve keys from Xendit Dashboard -> Developers -> API Keys
XENDIT_SECRET_KEY=xnd_development_your_secret_key
XENDIT_PUBLIC_KEY=xnd_public_development_your_public_key

# Webhook validation token. Find this in Xendit Dashboard -> Developers -> Webhooks
XENDIT_CALLBACK_TOKEN=your_xendit_webhook_callback_token

# ─── Biteship Logistics Integration (Courier aggregator) ──────────────────────
# Retrieve api keys from Biteship Dashboard -> Integration -> API Key
BITESHIP_API_KEY=biteship_test.your_biteship_api_key

# Warehouse settings for origin calculation
WAREHOUSE_AREA_ID=IDNP32IDNC88IDND6981IDZ26111
WAREHOUSE_ADDRESS=jln.Syech Ibrahim No.68E, Bukittinggi
WAREHOUSE_PHONE=+628211715945

# ─── Application Settings ─────────────────────────────────────────────────────
# The public URL of the deployed application (used for webhooks and auth redirection)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to "true" to display the top warning banner and the demo credentials floating panel.
NEXT_PUBLIC_IS_PROTOTYPE=true

# ─── Prototype Credentials ────────────────────────────────────────────────────
# Test accounts pre-populated on the login page when NEXT_PUBLIC_IS_PROTOTYPE=true
NEXT_PUBLIC_TEST_ADMIN_EMAIL=admin1@gmail.com
NEXT_PUBLIC_TEST_ADMIN_PASS=admin123

NEXT_PUBLIC_TEST_STAFF_EMAIL=staff1@gmail.com
NEXT_PUBLIC_TEST_STAFF_PASS=staff123

NEXT_PUBLIC_TEST_CUSTOMER_EMAIL=customer1@gmail.com
NEXT_PUBLIC_TEST_CUSTOMER_PASS=customer123
